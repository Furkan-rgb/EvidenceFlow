# Optional runtime and telemetry settings.
# Provider and model selection lives only in config/models.yaml.
EVIDENCEFLOW_DATA_DIR=data
EVIDENCEFLOW_RULES_CONFIG=config/review_rules.yaml
EVIDENCEFLOW_POLICIES_DIR=policies
# Uncomment only when Ollama is not at the base URL in config/models.yaml.
# OLLAMA_BASE_URL=http://127.0.0.1:11434
EVIDENCEFLOW_MAX_FILE_BYTES=10485760
EVIDENCEFLOW_MAX_BUNDLE_BYTES=26214400
EVIDENCEFLOW_MAX_PAGES=50
EVIDENCEFLOW_MLFLOW_ENABLED=true
EVIDENCEFLOW_MLFLOW_LOG_CONTENT=false
EVIDENCEFLOW_LOG_SENSITIVE_CONTENT=false
MLFLOW_TRACKING_URI=http://127.0.0.1:5001
MLFLOW_EXPERIMENT_NAME=evidenceflow
